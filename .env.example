# Copy this file to .env for local development.
# On Render, set these in the dashboard / render.yaml instead — see README.md.

# PostgreSQL connection string.
# Local example:   postgresql://postgres:postgres@localhost:5432/rateng
# Render provides this automatically when DATABASE_URL is wired to the
# rateng-db database in render.yaml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rateng

# Used to sign admin login tokens. Use a long random string in production
# (Render's render.yaml auto-generates one for you).
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cloudinary (free tier is enough to start) — used to store gallery images.
# Get these from https://cloudinary.com/console after signing up.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Creates the first admin login on the very first startup. Change this
# password immediately after logging in, via Admin -> Settings.
ADMIN_EMAIL=admin@ratengconstruction.com
ADMIN_PASSWORD=ChangeMe123!

# Comma-separated list of URLs allowed to call this API.
# Add your deployed frontend URL here once you have it, e.g.:
# CORS_ORIGINS=http://localhost:3000,https://rateng-frontend.onrender.com
CORS_ORIGINS=http://localhost:3000
